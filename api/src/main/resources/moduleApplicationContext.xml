<!-- Beans to add to the current Application context definition -->

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
  		    http://www.springframework.org/schema/beans/spring-beans-3.0.xsd
  		    http://www.springframework.org/schema/context
  		    http://www.springframework.org/schema/context/spring-context-3.0.xsd">

    <!-- The OpenmrsProfile filters keep exporters for optional modules (e.g. emrapi) out of the
         context when the module they depend on is not running -->
    <context:component-scan base-package="org.openmrs.module.metadataexport">
        <context:include-filter type="custom" expression="org.openmrs.annotation.OpenmrsProfileIncludeFilter" />
        <context:exclude-filter type="custom" expression="org.openmrs.annotation.OpenmrsProfileExcludeFilter" />
    </context:component-scan>

    <bean id="metadataexport.ExporterService"
            class="org.springframework.transaction.interceptor.TransactionProxyFactoryBean">
        <property name="transactionManager" ref="transactionManager" />
        <property name="target">
            <bean class="org.openmrs.module.metadataexport.api.impl.ExporterServiceImpl">
                <constructor-arg ref="domainExporterRegistry" />
            </bean>
        </property>
        <property name="preInterceptors">
            <ref bean="serviceInterceptors" />
        </property>
        <property name="transactionAttributeSource">
            <ref bean="transactionAttributeSource" />
        </property>
    </bean>

    <bean parent="serviceContext">
        <property name="moduleService">
            <list>
                <value>org.openmrs.module.metadataexport.api.ExporterService</value>
                <ref bean="metadataexport.ExporterService" />
            </list>
        </property>
    </bean>

</beans>
